# OpenRouter API key (required for extractor and drafting workflows)
OPENROUTER_API_KEY=sk-or-...

# libsodium key pair for PII encryption
# Public key is committed to repo; private key lives only here and in Actions secrets
CLAIMS_PUBLIC_KEY=base64-encoded-public-key
CLAIMS_PRIVATE_KEY=base64-encoded-private-key

# JWT signing key for consent tokens (generated in browser by site/consent.js)
# Not stored server-side; shown here for local testing only
CONSENT_JWT_SECRET=your-test-secret

# GitHub token for writing issue comments and labels (Actions uses GITHUB_TOKEN)
GITHUB_TOKEN=ghp_...
GITHUB_REPOSITORY=owner/repo

# Email (for user notifications)
# Resend or SendGrid API key
EMAIL_API_KEY=re_...
EMAIL_FROM=claims@yourdomain.example
